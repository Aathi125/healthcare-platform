PORT=8081
NODE_ENV=development
 
# OAuth2-first auth-service configuration

# Use a dedicated database name for auth (separate from patient-service `test` DB on same cluster).
# If PASS contains @ : / # etc., URL-encode it (e.g. myP@ss -> myP%40ss).
MONGODB_URI=mongodb+srv://USER:PASS@healthcare.xcbwhev.mongodb.net/healthcare_auth?retryWrites=true&w=majority&appName=Healthcare

# Example issuer for local Keycloak realm "healthcare":
OAUTH2_ISSUER_URL=http://localhost:8180/realms/healthcare
# Use the realm public key from Keycloak (Realm settings -> Keys -> RS256 public key).
# Keep as one line; escaped \n or plain base64 key are both accepted.
OAUTH2_PUBLIC_KEY=MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8A...
# Optional strict audience check:
# OAUTH2_AUDIENCE=healthcare-backend
OAUTH2_CLIENT_ID=healthcare-backend
# Required for OAuth2 refresh/logout proxy endpoints:
# - POST /api/auth/oauth/refresh
# - POST /api/auth/oauth/logout
OAUTH2_CLIENT_SECRET=replace-with-healthcare-backend-client-secret
#
# Required for OAuth2 registration provisioning endpoints:
# - POST /api/auth/oauth/register/patient
# - POST /api/auth/oauth/register/doctor
# Create a confidential Keycloak client with service accounts enabled
# and grant it realm-management roles to manage users/roles.
OAUTH2_ADMIN_CLIENT_ID=healthcare-admin
OAUTH2_ADMIN_CLIENT_SECRET=replace-with-admin-client-secret
# Optional (defaults to http://localhost:8180):
# KEYCLOAK_BASE_URL=http://localhost:8180
# Optional (defaults to realm extracted from OAUTH2_ISSUER_URL):
# KEYCLOAK_REALM=healthcare

SEED_ADMIN_EMAIL=admin@gmail.com
SEED_ADMIN_PASSWORD=Admin123
SEED_ADMIN_NAME=Platform Admin

AUTH_RATE_LIMIT_MAX=100

# In production, set allowed frontend origins as a comma-separated list.
# CORS_ORIGIN=http://localhost:3000,http://localhost:4200
