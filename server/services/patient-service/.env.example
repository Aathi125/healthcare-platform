# Patient Service Environment Variables

# Server Configuration
PORT=8084
NODE_ENV=development

# MongoDB (isolated database for patient-service)
MONGODB_URI=mongodb://localhost:27017/careline_patient_db

# Cloudinary (Image/Document Upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OAuth2 JWT Verification (must match auth-service Keycloak config)
# The patient-service verifies RS256 access tokens using the same public key
OAUTH2_ISSUER_URL=http://localhost:8180/realms/healthcare
OAUTH2_PUBLIC_KEY=<paste-keycloak-realm-RSA-public-key-here>
OAUTH2_CLIENT_ID=healthcare-backend

# Google Gemini AI (for medical text explanation)
GEMINI_API_KEY=your_gemini_api_key

# Service URLs (for inter-service communication)
AUTH_SERVICE_URL=http://localhost:8081
DOCTOR_SERVICE_URL=http://localhost:5003
APPOINTMENT_SERVICE_URL=http://localhost:5004

# CORS
CLIENT_URL=http://localhost:3000

# Logging
LOG_LEVEL=info

# App Info
APP_NAME=CareLine360
