PORT=4007
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000
# Patient search: GET /api/v1/consult/patients/search (proxied by Vite to this service)

# Base URL of auth-service (server-side proxy for patient directory search)
AUTH_SERVICE_URL=http://127.0.0.1:8081

# Service JWT used to authenticate doctor/patient/admin callers
AUTH_JWT_SECRET=replace_with_shared_auth_secret

# Twilio Video credentials (optional). If omitted, join returns a Jitsi Meet URL for local dev.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=replace_with_api_secret
TWILIO_TOKEN_TTL_SECONDS=3600
