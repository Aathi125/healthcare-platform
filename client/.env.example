# Unified dev server (run from client/): proxies are configured in vite.config.js
# - /api/auth         -> http://127.0.0.1:8081
# - /api/v1/video     -> http://127.0.0.1:4007
# - /api/v1/consult   -> http://127.0.0.1:4007 (patient directory search)
#
# Override only if you need absolute URLs (unusual):
# VITE_AUTH_API_BASE_URL=/api/auth
# VITE_TELEMEDICINE_API_BASE_URL=/api/v1/video
# VITE_CONSULT_API_BASE_URL=/api/v1/consult
